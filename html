<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="Money">
<title>Money Tracker</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap');
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --bg: #0e0e10; --surface: #1a1a1e; --surface2: #242428; --border: #2e2e34;
    --text: #f0f0f2; --muted: #6b6b78; --orange: #ff6b2b; --orange-dim: rgba(255,107,43,0.15);
    --green: #30d980; --red: #ff4d6a; --blue: #4d9fff; --purple: #a87fff; --yellow: #ffd166; --teal: #2dd4bf;
  }
  html, body { height: 100%; background: var(--bg); font-family: 'DM Sans', sans-serif; color: var(--text); overflow: hidden; }
  .app { display: flex; flex-direction: column; height: 100vh; height: 100dvh; }

  /* Status bar safe area */
  .status-bar { height: env(safe-area-inset-top, 44px); background: var(--bg); flex-shrink: 0; }

  .screen { flex: 1; overflow: hidden; position: relative; }
  .tab-content { display: none; height: 100%; flex-direction: column; }
  .tab-content.active { display: flex; animation: fadeUp 0.25s ease; }
  @keyframes fadeUp { from { opacity:0; transform:translateY(8px); } to { opacity:1; transform:translateY(0); } }

  /* ── HOME ── */
  .home-scroll { flex: 1; overflow-y: auto; padding: 0 20px 20px; -webkit-overflow-scrolling: touch; scrollbar-width: none; }
  .home-scroll::-webkit-scrollbar { display: none; }
  .home-header { padding: 20px 0 16px; }
  .home-header h1 { font-size: 13px; font-weight: 500; color: var(--muted); letter-spacing: 0.08em; text-transform: uppercase; }
  .balance-amount { font-size: 42px; font-weight: 300; color: var(--text); letter-spacing: -1px; margin-top: 4px; }
  .balance-amount span { font-size: 22px; color: var(--muted); }
  .balance-sub { font-size: 12px; color: var(--muted); margin-top: 4px; }

  .chart-card { background: var(--surface); border-radius: 20px; padding: 20px; margin-bottom: 16px; border: 1px solid var(--border); }
  .chart-title { font-size: 12px; font-weight: 500; color: var(--muted); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 16px; }
  .chart-body { display: flex; align-items: center; gap: 20px; }
  .donut-wrap { position: relative; width: 110px; height: 110px; flex-shrink: 0; }
  .donut-wrap svg { width: 110px; height: 110px; transform: rotate(-90deg); }
  .donut-center { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); text-align: center; }
  .donut-center-val { font-size: 16px; font-weight: 600; color: var(--text); }
  .donut-center-label { font-size: 10px; color: var(--muted); margin-top: 1px; }
  .legend { flex: 1; display: flex; flex-direction: column; gap: 8px; }
  .legend-item { display: flex; align-items: center; gap: 8px; }
  .legend-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
  .legend-name { font-size: 12px; color: var(--muted); flex: 1; }
  .legend-pct { font-size: 12px; font-weight: 500; color: var(--text); }

  .section-label { font-size: 12px; font-weight: 500; color: var(--muted); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 10px; }
  .txn-list { display: flex; flex-direction: column; gap: 8px; }
  .txn-item { background: var(--surface); border-radius: 14px; padding: 12px 14px; display: flex; align-items: center; gap: 12px; border: 1px solid var(--border); }
  .txn-icon { width: 36px; height: 36px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 16px; flex-shrink: 0; }
  .txn-info { flex: 1; min-width: 0; }
  .txn-name { font-size: 14px; font-weight: 500; color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .txn-cat { font-size: 11px; color: var(--muted); margin-top: 1px; }
  .txn-amount { font-size: 14px; font-weight: 600; font-family: 'DM Mono', monospace; white-space: nowrap; }
  .txn-amount.neg { color: var(--red); }
  .txn-amount.pos { color: var(--green); }

  /* ── ADD ── */
  .add-screen { padding: 20px; display: flex; flex-direction: column; gap: 16px; height: 100%; overflow-y: auto; -webkit-overflow-scrolling: touch; scrollbar-width: none; }
  .add-screen::-webkit-scrollbar { display: none; }
  .add-title { font-size: 22px; font-weight: 600; color: var(--text); }
  .type-toggle { display: flex; background: var(--surface); border-radius: 12px; padding: 4px; gap: 4px; }
  .type-btn { flex: 1; padding: 8px; border: none; border-radius: 9px; font-size: 13px; font-weight: 500; font-family: 'DM Sans', sans-serif; cursor: pointer; transition: all 0.2s; background: transparent; color: var(--muted); }
  .type-btn.active-expense { background: var(--orange); color: #fff; }
  .type-btn.active-income { background: var(--green); color: #111; }
  .amount-input-wrap { text-align: center; padding: 10px 0; }
  .currency-sym { font-size: 28px; color: var(--muted); vertical-align: top; margin-top: 8px; }
  .amount-input { background: transparent; border: none; outline: none; font-size: 52px; font-weight: 300; color: var(--text); width: 180px; text-align: center; font-family: 'DM Sans', sans-serif; letter-spacing: -2px; }
  .field-label { font-size: 11px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 6px; }
  .field-input { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; padding: 12px 14px; color: var(--text); font-size: 14px; font-family: 'DM Sans', sans-serif; width: 100%; outline: none; -webkit-appearance: none; }
  .field-input:focus { border-color: var(--orange); }
  .cat-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; }
  .cat-btn { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; padding: 10px 6px; display: flex; flex-direction: column; align-items: center; gap: 4px; cursor: pointer; transition: all 0.2s; font-size: 18px; }
  .cat-btn span { font-size: 10px; color: var(--muted); font-family: 'DM Sans', sans-serif; }
  .cat-btn.selected { border-color: var(--orange); background: var(--orange-dim); }
  .cat-btn.selected span { color: var(--orange); }
  .add-btn { background: var(--orange); border: none; border-radius: 16px; padding: 16px; color: #fff; font-size: 16px; font-weight: 600; font-family: 'DM Sans', sans-serif; cursor: pointer; width: 100%; margin-top: auto; box-shadow: 0 8px 24px rgba(255,107,43,0.4); transition: transform 0.1s; }
  .add-btn:active { transform: scale(0.97); }

  /* ── HISTORY ── */
  .history-screen { padding: 20px; overflow-y: auto; flex: 1; -webkit-overflow-scrolling: touch; scrollbar-width: none; }
  .history-screen::-webkit-scrollbar { display: none; }
  .history-title { font-size: 22px; font-weight: 600; color: var(--text); margin-bottom: 16px; }
  .month-group { margin-bottom: 20px; }
  .month-label { font-size: 11px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 8px; }

  /* ── TAB BAR ── */
  .tab-bar {
    background: var(--surface); border-top: 1px solid var(--border);
    display: flex; align-items: flex-start; padding-top: 10px; flex-shrink: 0;
    padding-bottom: env(safe-area-inset-bottom, 16px);
  }
  .tab-item { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 3px; cursor: pointer; padding: 0 4px; }
  .tab-icon { font-size: 20px; line-height: 1; }
  .tab-label { font-size: 10px; color: var(--muted); font-weight: 500; }
  .tab-item.active .tab-label { color: var(--orange); }
  .fab-wrap { flex: 1; display: flex; justify-content: center; }
  .fab { width: 52px; height: 52px; border-radius: 50%; background: var(--orange); border: none; cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 28px; color: #fff; box-shadow: 0 6px 20px rgba(255,107,43,0.5); transition: transform 0.15s; margin-top: -20px; }
  .fab:active { transform: scale(0.93); }

  /* Toast */
  .toast { position: fixed; bottom: 120px; left: 50%; transform: translateX(-50%) translateY(20px); background: var(--green); color: #111; padding: 10px 20px; border-radius: 20px; font-size: 13px; font-weight: 600; opacity: 0; transition: all 0.3s; pointer-events: none; white-space: nowrap; z-index: 100; }
  .toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

  /* Delete btn in history */
  .txn-delete { background: none; border: none; color: var(--muted); font-size: 16px; cursor: pointer; padding: 4px; flex-shrink: 0; }
</style>
</head>
<body>
<div class="app">
  <div class="status-bar"></div>
  <div class="screen">

    <div class="tab-content active" id="tab-home">
      <div class="home-scroll">
        <div class="home-header">
          <h1 id="month-label">May 2026</h1>
          <div class="balance-amount"><span>$</span><span id="total-spent">0.00</span></div>
          <div class="balance-sub">total spent this month</div>
        </div>
        <div class="chart-card">
          <div class="chart-title">By category</div>
          <div class="chart-body">
            <div class="donut-wrap">
              <svg viewBox="0 0 36 36" id="donut-svg">
                <circle cx="18" cy="18" r="15.9" fill="none" stroke="var(--surface2)" stroke-width="3.5"/>
              </svg>
              <div class="donut-center">
                <div class="donut-center-val" id="donut-pct">—</div>
                <div class="donut-center-label" id="donut-top">top</div>
              </div>
            </div>
            <div class="legend" id="donut-legend"><div style="font-size:12px;color:var(--muted)">No data yet</div></div>
          </div>
        </div>
        <div class="section-label">Recent</div>
        <div class="txn-list" id="txn-list">
          <div style="font-size:13px;color:var(--muted);padding:10px 0">No transactions yet. Tap + to add one.</div>
        </div>
      </div>
    </div>

    <div class="tab-content" id="tab-add">
      <div class="add-screen">
        <div class="add-title">New entry</div>
        <div class="type-toggle">
          <button class="type-btn active-expense" id="btn-expense" onclick="setType('expense')">Expense</button>
          <button class="type-btn" id="btn-income" onclick="setType('income')">Income</button>
        </div>
        <div class="amount-input-wrap">
          <span class="currency-sym">$</span>
          <input class="amount-input" id="amount-input" type="number" placeholder="0" min="0" step="0.01" inputmode="decimal">
        </div>
        <div>
          <div class="field-label">Description</div>
          <input class="field-input" id="desc-input" type="text" placeholder="What was it for?">
        </div>
        <div>
          <div class="field-label">Category</div>
          <div class="cat-grid" id="cat-grid"></div>
        </div>
        <button class="add-btn" onclick="addEntry()">Add Entry</button>
      </div>
    </div>

    <div class="tab-content" id="tab-history">
      <div class="history-screen">
        <div class="history-title">History</div>
        <div id="history-list"><div style="font-size:13px;color:var(--muted)">No transactions yet.</div></div>
      </div>
    </div>

  </div>

  <div class="tab-bar">
    <div class="tab-item active" id="nav-home" onclick="switchTab('home')">
      <span class="tab-icon">◎</span>
      <span class="tab-label">Overview</span>
    </div>
    <div class="fab-wrap">
      <button class="fab" onclick="switchTab('add')">+</button>
    </div>
    <div class="tab-item" id="nav-history" onclick="switchTab('history')">
      <span class="tab-icon">≡</span>
      <span class="tab-label">History</span>
    </div>
  </div>
</div>

<div class="toast" id="toast">Entry added ✓</div>

<script>
const CATS = [
  {id:'food',     emoji:'🍔', label:'Food',    color:'#ff6b2b'},
  {id:'transport',emoji:'🚇', label:'Transit', color:'#4d9fff'},
  {id:'shopping', emoji:'🛍️', label:'Shop',    color:'#a87fff'},
  {id:'health',   emoji:'💊', label:'Health',  color:'#2dd4bf'},
  {id:'bills',    emoji:'💡', label:'Bills',   color:'#ffd166'},
  {id:'fun',      emoji:'🎮', label:'Fun',     color:'#ff4d6a'},
  {id:'travel',   emoji:'✈️', label:'Travel',  color:'#30d980'},
  {id:'other',    emoji:'📦', label:'Other',   color:'#6b6b78'},
];

let entries = JSON.parse(localStorage.getItem('money_entries_v2') || '[]');
let currentType = 'expense';
let selectedCat = 'food';

// Build cat grid
const grid = document.getElementById('cat-grid');
CATS.forEach(c => {
  const btn = document.createElement('button');
  btn.className = 'cat-btn' + (c.id===selectedCat?' selected':'');
  btn.dataset.id = c.id;
  btn.innerHTML = `${c.emoji}<span>${c.label}</span>`;
  btn.onclick = () => {
    document.querySelectorAll('.cat-btn').forEach(b=>b.classList.remove('selected'));
    btn.classList.add('selected');
    selectedCat = c.id;
  };
  grid.appendChild(btn);
});

// Month label
const now = new Date();
document.getElementById('month-label').textContent =
  now.toLocaleString('default',{month:'long',year:'numeric'});

function setType(t) {
  currentType = t;
  document.getElementById('btn-expense').className = 'type-btn'+(t==='expense'?' active-expense':'');
  document.getElementById('btn-income').className  = 'type-btn'+(t==='income'?' active-income':'');
}

function switchTab(name) {
  document.querySelectorAll('.tab-content').forEach(el=>el.classList.remove('active'));
  document.querySelectorAll('.tab-item').forEach(el=>el.classList.remove('active'));
  document.getElementById('tab-'+name).classList.add('active');
  if (name!=='add') document.getElementById('nav-'+name)?.classList.add('active');
  if (name==='home') renderHome();
  if (name==='history') renderHistory();
}

function save() { localStorage.setItem('money_entries_v2', JSON.stringify(entries)); }

function addEntry() {
  const amt = parseFloat(document.getElementById('amount-input').value);
  const desc = document.getElementById('desc-input').value.trim() || 'Untitled';
  if (!amt || amt<=0) { alert('Please enter a valid amount'); return; }
  const cat = CATS.find(c=>c.id===selectedCat);
  entries.unshift({ id:Date.now(), type:currentType, amount:amt, desc, cat:cat.id, emoji:cat.emoji, color:cat.color, label:cat.label, date:new Date().toISOString() });
  save();
  document.getElementById('amount-input').value = '';
  document.getElementById('desc-input').value = '';
  showToast();
  switchTab('home');
}

function deleteEntry(id) {
  entries = entries.filter(e=>e.id!==id);
  save();
  renderHistory();
  renderHome();
}

function showToast() {
  const t = document.getElementById('toast');
  t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'), 2000);
}

function renderHome() {
  const n = new Date();
  const monthEntries = entries.filter(e=>{
    const d=new Date(e.date);
    return d.getMonth()===n.getMonth()&&d.getFullYear()===n.getFullYear()&&e.type==='expense';
  });
  const total = monthEntries.reduce((s,e)=>s+e.amount,0);
  document.getElementById('total-spent').textContent = total.toFixed(2);

  const bycat = {};
  monthEntries.forEach(e=>{ bycat[e.cat]=(bycat[e.cat]||0)+e.amount; });
  const sorted = Object.entries(bycat).sort((a,b)=>b[1]-a[1]);
  renderDonut(sorted, total);

  const list = document.getElementById('txn-list');
  const recent = entries.slice(0,8);
  if (!recent.length) { list.innerHTML='<div style="font-size:13px;color:var(--muted);padding:10px 0">No transactions yet. Tap + to add one.</div>'; return; }
  list.innerHTML = recent.map(e=>`
    <div class="txn-item">
      <div class="txn-icon" style="background:${e.color}22">${e.emoji}</div>
      <div class="txn-info">
        <div class="txn-name">${e.desc}</div>
        <div class="txn-cat">${e.label}</div>
      </div>
      <div class="txn-amount ${e.type==='expense'?'neg':'pos'}">${e.type==='expense'?'-':'+'}$${e.amount.toFixed(2)}</div>
    </div>`).join('');
}

function renderDonut(sorted, total) {
  const svg = document.getElementById('donut-svg');
  svg.querySelectorAll('.seg').forEach(el=>el.remove());
  const legend = document.getElementById('donut-legend');
  if (!sorted.length||total===0) {
    legend.innerHTML='<div style="font-size:12px;color:var(--muted)">No expenses yet</div>';
    document.getElementById('donut-pct').textContent='—';
    document.getElementById('donut-top').textContent='top';
    return;
  }
  const r=15.9, circ=2*Math.PI*r;
  let offset=0;
  const colors={};
  CATS.forEach(c=>{colors[c.id]=c.color;});
  sorted.forEach(([catId,amt])=>{
    const pct=amt/total, dash=pct*circ, gap=circ-dash;
    const circle=document.createElementNS('http://www.w3.org/2000/svg','circle');
    circle.setAttribute('cx','18'); circle.setAttribute('cy','18'); circle.setAttribute('r',r);
    circle.setAttribute('fill','none'); circle.setAttribute('stroke',colors[catId]||'#888');
    circle.setAttribute('stroke-width','3.5');
    circle.setAttribute('stroke-dasharray',`${dash} ${gap}`);
    circle.setAttribute('stroke-dashoffset',-offset*circ);
    circle.setAttribute('stroke-linecap','round');
    circle.classList.add('seg');
    svg.appendChild(circle);
    offset+=pct;
  });
  const topCat=CATS.find(c=>c.id===sorted[0][0]);
  document.getElementById('donut-pct').textContent=Math.round(sorted[0][1]/total*100)+'%';
  document.getElementById('donut-top').textContent=topCat?.label||'';
  legend.innerHTML=sorted.slice(0,4).map(([catId,amt])=>{
    const c=CATS.find(x=>x.id===catId);
    return `<div class="legend-item">
      <div class="legend-dot" style="background:${c?.color||'#888'}"></div>
      <span class="legend-name">${c?.label||catId}</span>
      <span class="legend-pct">${Math.round(amt/total*100)}%</span>
    </div>`;
  }).join('');
}

function renderHistory() {
  const container=document.getElementById('history-list');
  if (!entries.length) { container.innerHTML='<div style="font-size:13px;color:var(--muted)">No transactions yet.</div>'; return; }
  const groups={};
  entries.forEach(e=>{
    const d=new Date(e.date);
    const key=d.toLocaleString('default',{month:'long',year:'numeric'});
    if (!groups[key]) groups[key]=[];
    groups[key].push(e);
  });
  container.innerHTML=Object.entries(groups).map(([month,list])=>`
    <div class="month-group">
      <div class="month-label">${month}</div>
      <div class="txn-list">
        ${list.map(e=>`
          <div class="txn-item">
            <div class="txn-icon" style="background:${e.color}22">${e.emoji}</div>
            <div class="txn-info">
              <div class="txn-name">${e.desc}</div>
              <div class="txn-cat">${e.label} · ${new Date(e.date).toLocaleDateString()}</div>
            </div>
            <div class="txn-amount ${e.type==='expense'?'neg':'pos'}">${e.type==='expense'?'-':'+'}$${e.amount.toFixed(2)}</div>
            <button class="txn-delete" onclick="deleteEntry(${e.id})">✕</button>
          </div>`).join('')}
      </div>
    </div>`).join('');
}

renderHome();
</script>
</body>
</html>
